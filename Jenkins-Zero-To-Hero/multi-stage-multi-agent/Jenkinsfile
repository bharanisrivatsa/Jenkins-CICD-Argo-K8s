pipeline {
    agent {
        docker {
            // Standard Maven image to handle the build process
            image 'maven:3.8.6-eclipse-temurin-11'
            args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    options {
        // Prevents Jenkins from trying to checkout before we can clean the workspace
        skipDefaultCheckout()
    }

    environment {
        // Define your Docker Hub image name here
        DOCKER_IMAGE = "bharani301085/ultimate-cicd"
        SONAR_URL = "http://18.234.67.228:9000"
    }

    stages {
        stage('Initialize & Checkout') {
            steps {
                // 1. Wipe out any old files owned by 'root' from previous builds
                cleanWs()
                // 2. Freshly pull the code from Git
                checkout scm
            }
        }

        stage('Build and Test') {
            steps {
                // Navigate into the specific folder where the pom.xml lives
                dir('Jenkins-Zero-To-Hero/java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
                    sh 'mvn clean package'
                }
            }
        }

        stage('Static Code Analysis') {
            steps {
                dir('Jenkins-Zero-To-Hero/java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
                    withCredentials([string(credentialsId: 'SonarQube', variable: 'SONAR_AUTH_TOKEN')]) {
                        sh "mvn sonar:sonar -Dsonar.login=\$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}"
                    }
                }
            }
        }

        stage('Build and Push Docker Image') {
            steps {
                script {
                    dir('Jenkins-Zero-To-Hero/java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
                        // Build the image using the current Jenkins Build Number as the tag
                        sh "docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} ."
                        
                        // Push to Docker Hub using your credentials ID 'docker-cred'
                        docker.withRegistry('https://index.docker.io/v1/', "docker-cred") {
                            sh "docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}"
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Successfully built and pushed ${DOCKER_IMAGE}:${BUILD_NUMBER}"
        }
        always {
            // Optional: Remove the local image from the EC2 to save disk space
            sh "docker rmi ${DOCKER_IMAGE}:${BUILD_NUMBER} || true"
        }
    }
}
